server {
    listen {{ lighthouse_nginx_port }};
    server_name {{ lighthouse_nginx_server_name }};

    root {{ lighthouse_install_dir }};
    index index.html;

    access_log /var/log/nginx/lighthouse_access.log;
    error_log  /var/log/nginx/lighthouse_error.log;

    location / {
        try_files $uri $uri/ =404;
    }
}
